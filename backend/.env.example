# Core
APP_NAME=ZARA AI Backend
APP_VERSION=0.1.0
DEFAULT_MODE=smart

# OpenRouter (primary)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_TIMEOUT_S=10
OPENROUTER_TEMPERATURE=0.65
OPENROUTER_MAX_TOKENS=720

# Ollama (offline fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_FALLBACK_MODEL=gemma2:2b
OLLAMA_TIMEOUT_S=8
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=260

# Voice pipeline
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MAX_AUDIO_SECONDS=8

# Performance tuning
CACHE_TTL_SECONDS=90
CACHE_MAX_ENTRIES=256
MEMORY_LIMIT=12

# Safe automation
AUTOMATION_EXECUTE=false

# Optional Coqui TTS
TTS_ENABLED=false
TTS_MODEL_NAME=tts_models/en/ljspeech/tacotron2-DDC_ph

# Gunicorn
PORT=8000
WEB_CONCURRENCY=1

# Frontend origins allowed to call backend from browser
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173
